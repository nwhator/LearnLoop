# LearnLoop Environment Variables

# Supabase Configuration
# Get these from Settings -> API in your Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here (Only for server-side code)

# Google Gemini API Key
# Get this from https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# NextAuth Secret (If you use authentication)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
